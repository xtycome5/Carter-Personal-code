# App
APP_NAME=DreamRecorder
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dreamrecorder

# DashScope AI API (Alibaba Cloud Model Studio)
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com

# Models (可切换)
QWEN_MODEL=qwen-plus
IMAGE_MODEL=wan2.6-image
VIDEO_MODEL=wan2.7-t2v-2026-04-25

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/callback/github

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
