# ============================================================
# Dream Recorder - 环境变量说明
# ============================================================
#
# 本项目涉及两类密钥，用途不同：
#
# ┌─────────────────────────────────────────────────────────────┐
# │  1. 阿里云 AKSK（用于开设云资源）                           │
# │     填写位置: aliyun CLI 配置 或 环境变量                    │
# │     获取方式: 阿里云控制台 → RAM → AccessKey 管理            │
# │     用途: 创建 ECS、VPC、安全组等基础设施                    │
# ├─────────────────────────────────────────────────────────────┤
# │  2. DashScope API Key（用于调用 AI 模型）                   │
# │     填写位置: backend/.env 中的 DASHSCOPE_API_KEY           │
# │     获取方式: 阿里云百炼控制台 → API Key 管理                │
# │     用途: 调用 Qwen 文本模型、万相图片/视频生成模型          │
# └─────────────────────────────────────────────────────────────┘
#
# ============================================================

# ========================
# 方式一：环境变量（推荐用于 CI/CD 或脚本调用）
# ========================
# 在终端中 export 后，运行 deploy/provision-cloud.sh 即可开设资源

# 阿里云主账号或 RAM 子账号的 AccessKey
export ALIBABA_CLOUD_ACCESS_KEY_ID="your-access-key-id-here"
export ALIBABA_CLOUD_ACCESS_KEY_SECRET="your-access-key-secret-here"

# 可选：指定默认 Region
export ALIBABA_CLOUD_REGION="ap-southeast-1"


# ========================
# 方式二：aliyun CLI 交互配置（推荐首次使用）
# ========================
# 运行以下命令，按提示输入 AKSK:
#
#   aliyun configure
#
# 它会询问:
#   - Access Key ID
#   - Access Key Secret
#   - Default Region (输入: ap-southeast-1)
#   - Default Language (输入: zh)
#
# 配置保存在 ~/.aliyun/config.json


# ========================
# 方式三：直接传递给脚本（临时使用）
# ========================
# ALIBABA_CLOUD_ACCESS_KEY_ID=xxx ALIBABA_CLOUD_ACCESS_KEY_SECRET=yyy bash deploy/provision-cloud.sh
